# Провайдер для написания описаний: openai (по умолчанию) | claude
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_DIGEST_MODEL=gpt-4o-mini

# Claude (для LLM_PROVIDER=claude) — модель по умолчанию claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

DIGEST_REBUILD_TOKEN=change-me
CONTENT_AUTOMATION_TOKEN=change-me
HOST=127.0.0.1
PORT=5173
