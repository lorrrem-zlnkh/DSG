OPENAI_API_KEY=sk-...
OPENAI_DIGEST_MODEL=gpt-4o-mini
DIGEST_REBUILD_TOKEN=change-me
CONTENT_AUTOMATION_TOKEN=change-me
HOST=127.0.0.1
PORT=5173

# Telegram digest bot
TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=123456789
TELEGRAM_CHANNEL_ID=@lorrrem
TELEGRAM_WEBHOOK_SECRET=long-random-secret
PUBLIC_SITE_URL=http://dsg.lorrrem.ru
# Telegram webhooks require HTTPS. Set this if PUBLIC_SITE_URL is HTTP.
# TELEGRAM_WEBHOOK_URL=https://dsg.lorrrem.ru/api/telegram/webhook
DIGEST_REVIEW_DAY=1
DIGEST_REVIEW_HOUR=10
DIGEST_BOT_POLL_INTERVAL_MS=3000

# Optional: call a deploy webhook after approval. Do not point this to /api/automation/run,
# because that endpoint rebuilds content and can bypass the reviewed draft.
DIGEST_SITE_PUBLISH_URL=https://deploy-hook.example
DIGEST_SITE_PUBLISH_TOKEN=change-me

# Optional alternative to webhook, runs on the server after approval.
# DIGEST_SITE_PUBLISH_COMMAND=sh scripts/deploy-public.sh
