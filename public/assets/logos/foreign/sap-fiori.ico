        <h2 id="universal-by-design">Universal by Design</h2>
        <p>A design system built to adapt to users, devices, and preferences in order to bring out the best in any enterprise.</p>
        <div class="cards">
          <div>
            <div>
              <picture>
                <source type="image/webp" srcset="./media_183c4dfb7bb7af92d949de6d9ba6999e01d48fbc6.png?width=2000&#x26;format=webply&#x26;optimize=medium" media="(min-width: 600px)">
